# Copy this to .env and fill in your values
# NEVER commit .env to GitHub

# Supabase (https://supabase.com → Project Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-public-key

# WhatsApp Cloud API (https://developers.facebook.com → Your App → WhatsApp → API Setup)
WHATSAPP_TOKEN=your-permanent-token
WHATSAPP_PHONE_ID=your-phone-number-id

# Razorpay (https://dashboard.razorpay.com → Settings → API Keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-key-secret

# App settings (optional — defaults shown)
APP_ENV=development
REMINDER_INTERVAL_HOURS=1
REMINDER_BEFORE_HOURS=24
NOSHOW_CHECK_MINUTES=30
JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars
JWT_EXPIRE_HOURS=24
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret-from-dashboard
